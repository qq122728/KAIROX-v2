# SQLite database used by the Next app and test harness.
# Use an absolute path in production, or a repo-relative path for local work.
PERP_SIM_DB_PATH=./data/perp-lab.sqlite

# Public HTTP origin for the Next app. The socket server uses this for CORS.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:3001
PERP_SIM_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
PORT=3000
NEXT_HOSTNAME=0.0.0.0

# Socket.IO service configuration.
SOCKET_PORT=3001
SOCKET_INTERNAL_URL=http://127.0.0.1:3001/internal/emit

# Required in production. Use one long random value shared by Next, socket, and settlement.
SOCKET_INTERNAL_SECRET=
REALTIME_INTERNAL_SECRET=

# Optional first-run seed credentials. Leave unset after the initial admin exists.
PERP_SIM_ADMIN_PASSWORD=
PERP_SIM_BACKFILL_WITHDRAWAL_PASSWORD=
PERP_SIM_DEMO_MODE=false
PERP_SIM_DEMO_PASSWORD=

# Market/settlement tuning.
SETTLEMENT_INTERVAL_MS=1000
MARKET_DATA_FETCH_TIMEOUT_MS=2500
OKX_API_BASE_URL=https://www.okx.com

# Regression test safety. Prefer a disposable DB instead of enabling this.
PERP_SIM_ALLOW_DEFAULT_DB_FOR_TESTS=false
