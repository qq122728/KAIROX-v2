# VORX Beta environment template
# Copy to .env.local for local work or .env.production.local on the server.
# Replace every placeholder before running production. Never commit real secrets.

# Runtime
NODE_ENV=<development-or-production>
PORT=<next-app-port>
NEXT_HOSTNAME=<next-bind-host>

# SQLite database used by the Next app, socket server, settlement worker, and tests.
PERP_SIM_DB_PATH=<absolute-or-relative-sqlite-path>
PERP_SIM_SQLITE_BUSY_TIMEOUT_MS=<sqlite-busy-timeout-ms>
SQLITE_BUSY_TIMEOUT_MS=<legacy-sqlite-busy-timeout-ms>

# Public origins
NEXT_PUBLIC_APP_URL=<public-app-origin>
NEXT_PUBLIC_SOCKET_URL=<public-socket-origin>
PERP_SIM_ALLOWED_ORIGINS=<comma-separated-allowed-origins>

# Socket.IO service
SOCKET_HOST=<socket-bind-host>
SOCKET_PORT=<socket-port>
SOCKET_INTERNAL_URL=<socket-internal-emit-url>
SOCKET_SQLITE_BUSY_TIMEOUT_MS=<socket-sqlite-busy-timeout-ms>

# Required in production.
# Use one long random value shared by Next, socket, and settlement.
SOCKET_INTERNAL_SECRET=<long-random-internal-secret>
REALTIME_INTERNAL_SECRET=<same-long-random-internal-secret>

# Settlement worker and market data
SETTLEMENT_INTERVAL_MS=<settlement-interval-ms>
SETTLEMENT_SQLITE_BUSY_TIMEOUT_MS=<settlement-sqlite-busy-timeout-ms>
PRICE_TICK_MIN_INTERVAL_SECONDS=<price-tick-min-interval-seconds>
MARKET_DATA_FETCH_TIMEOUT_MS=<market-data-fetch-timeout-ms>
OKX_API_BASE_URL=<okx-api-base-url>
BINANCE_API_BASE_URL=<binance-api-base-url>

# Rate limits
PERP_SIM_LOGIN_MAX_FAILURES=<user-login-max-failures>
PERP_SIM_ADMIN_LOGIN_MAX_FAILURES=<admin-login-max-failures>
PERP_SIM_LOGIN_LOCK_MS=<user-login-lock-ms>
PERP_SIM_ADMIN_LOGIN_LOCK_MS=<admin-login-lock-ms>
PERP_SIM_REGISTER_LIMIT=<register-limit>
PERP_SIM_REGISTER_WINDOW_MS=<register-window-ms>
PERP_SIM_SWAP_LIMIT=<swap-submit-limit>
PERP_SIM_SWAP_WINDOW_MS=<swap-submit-window-ms>
PERP_SIM_SWAP_QUOTE_LIMIT=<swap-quote-limit>
PERP_SIM_SWAP_QUOTE_WINDOW_MS=<swap-quote-window-ms>
PERP_SIM_BINARY_ORDER_LIMIT=<binary-order-limit>
PERP_SIM_BINARY_ORDER_WINDOW_MS=<binary-order-window-ms>
PERP_SIM_WITHDRAW_PASSWORD_LIMIT=<withdraw-password-failure-limit>
PERP_SIM_WITHDRAW_PASSWORD_WINDOW_MS=<withdraw-password-window-ms>
PERP_SIM_DEPOSIT_LIMIT=<deposit-submit-limit>
PERP_SIM_DEPOSIT_WINDOW_MS=<deposit-submit-window-ms>

# Optional first-run seed credentials.
# Set only for initial setup, then remove from production.
PERP_SIM_ADMIN_PASSWORD=<temporary-admin-password>
PERP_SIM_BACKFILL_WITHDRAWAL_PASSWORD=<temporary-withdrawal-password>
PERP_SIM_DEMO_MODE=<true-or-false>
PERP_SIM_DEMO_PASSWORD=<temporary-demo-password>

# Admin notification thresholds
NEXT_PUBLIC_ADMIN_BIG_BINARY_STAKE=<large-binary-stake-threshold>
NEXT_PUBLIC_ADMIN_BIG_TRADE_NOTIONAL=<large-trade-notional-threshold>

# Test-only variables
TEST_APP_URL=<test-app-origin>
TEST_SOCKET_URL=<test-socket-origin>
TEST_DB_PATH=<test-sqlite-path>
TEST_ARTIFACT_DIR=<test-artifact-directory>
PLAYWRIGHT_CHANNEL=<playwright-browser-channel>
PERP_SIM_ALLOW_DEFAULT_DB_FOR_TESTS=<true-or-false>
